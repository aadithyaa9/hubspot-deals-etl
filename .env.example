# ─── HubSpot ─────────────────────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=your_private_app_token_here
HUBSPOT_API_BASE_URL=https://api.hubapi.com

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=hubspot_etl
POSTGRES_USER=etl_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Convenience full DSN (used by Django & DLT)
DATABASE_URL=postgresql://etl_user:change_me_in_production@db:5432/hubspot_etl

# ─── Django ───────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-with-a-long-random-string-50-chars-min
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ─── API Server ───────────────────────────────────────────────────────────────
API_PORT=8000
